  "grammar": {
    "cards": [
      {
        "marker": "①",
        "title": "受身「～(ら)れる／～ぜられる」",
        "desc": "「安住は張学究に育てられ」「陳留県（尉）に任ぜられた」——“安住由张学究抚养长大”“被任命为陈留县（尉）”。被动态叙述人物遭遇；「任ずる」的被动古形为「任ぜられる」。"
      },
      {
        "marker": "②",
        "title": "推量・自発「～(え)よう」",
        "desc": "「話本としての性格がよくうかがえよう」——“足见其作为话本的性格”。可能形「うかがえ」＋文语推量「よう」，使判断显得审慎，可译“足见、可窥见”。"
      },
      {
        "marker": "③",
        "title": "連用中止法",
        "desc": "「相ついで世を去り、…育てられ、…両親のことを知り、…帰る」——用动词连用形（去り・育てられ・知り）串联多个分句，是书面叙事文体的连缀手法。"
      },
      {
        "marker": "④",
        "title": "～ず（否定中止・漢文訓読調）",
        "desc": "「安住を甥とは認めず、頭をなぐりつける」——「ず」是否定助动词「ない」的文语连用形，“不承认（是侄儿）……（而）……”，承自汉文训读调。"
      },
      {
        "marker": "⑤",
        "title": "～をもって（文语・手段）",
        "desc": "「七言の詩をもってむすび」——“以一首七言诗收束”。「をもって」表手段、凭借，相当于“以、用”。"
      },
      {
        "marker": "⑥",
        "title": "～にして（文语）",
        "desc": "「偕老百年にして終えた」——“白头偕老、共度百年而终”。文语「にして」连接状态或时间，含“处于……之中而”之意。"
      },
      {
        "marker": "⑦",
        "title": "引用「～という／と＋締めくくる」",
        "desc": "「…偕老百年にして終えた。という」「『話本説徹、権作散場』としめくくる」——「という」收束所转述的故事梗概（“据说如此”）；「と＋しめくくる」＝“以……作结”，皆为引用句式。"
      },
      {
        "marker": "⑧",
        "title": "～(よ)うとすると",
        "desc": "「添祥を打とうとすると、安住がかばう」——意志形「打とう」＋「とすると」，“正要责打（添祥）时（安住却出面回护）”，表动作将发生之际。"
      },
      {
        "marker": "⑨",
        "title": "～たところ（结果・契机）",
        "desc": "「朝廷に奏上したところ、陳留県に任ぜられた」——“向朝廷奏报，（结果）被任命为陈留县”。「～たところ」表某动作之后随即出现的结果。"
      }
    ],
    "note": "※ 语法分析以现代日语为主，兼及汉文训读调与文语残留。"
  },
