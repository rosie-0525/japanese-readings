  "grammar": {
    "cards": [
      {
        "marker": "①",
        "title": "～ものであろう（推量）",
        "desc": "「朝字が相字と似るところから誤ったものであろう」——“大概是因‘朝’与‘相’字形相近而致误的吧”。「ものだ」表对事情成因的解释，加推量「であろう」缓和断定。"
      },
      {
        "marker": "②",
        "title": "～ではないか（推测·反问）",
        "desc": "「『簡帖和尚』のことではないか」「林沖の故事ではないか」——“恐怕就是……吧”。表带有把握的推测，本节考订诸题本事多用此式。"
      },
      {
        "marker": "③",
        "title": "～という（伝聞·転述）",
        "desc": "「それはその別名である、という」「同一の題材ではないか、という」——句末「という」转述他人之说，承接谭正璧・赵景深等诸家的考证。"
      },
      {
        "marker": "④",
        "title": "～とあり／とある（漢文訓読調·引用）",
        "desc": "「題下の注に、胡姑姑、錯下書とあり」——“题下的注中写作‘胡姑姑’‘错下书’”。「とある」指代所引文字，是训读体的引文句法。"
      },
      {
        "marker": "⑤",
        "title": "～に見える／見られる（所見·徴引）",
        "desc": "「『宝文堂書目』に見える『勘靴児』」「『四庫全書総目』に見られる十七巻本」——“见于《……》的《……》”，表示某篇某本见载于某书。"
      },
      {
        "marker": "⑥",
        "title": "受身 ～られる／される",
        "desc": "「治州に流される」「結婚を許される」「文采をめでられ」「犯罪・裁判にかかわるものと解される」——被动态，叙述人物遭遇与对内容的判断。"
      },
      {
        "marker": "⑦",
        "title": "～知られよう（受身＋推量）",
        "desc": "「公案ものが多くの話柄を提供していることが知られよう」——“可见公案题材提供了大量话柄（吧）”。「知る」受身「知られる」＋推量「よう」，意为“可知、可见”。"
      },
      {
        "marker": "⑧",
        "title": "～てよい（かもしれない）（許容·評価）",
        "desc": "「林沖の故事もあってよいかもしれない」「参考にされてよい書」「判例の解説書といってよい」——表“也未必没有／值得参考／可谓……”的容许性判断。"
      },
      {
        "marker": "⑨",
        "title": "～にほかならない／～とされる",
        "desc": "「『墨場必携』にほかならない、とされる」——“（被认为）无异于一部‘墨场必携’”。「にほかならない」表“正是、无异于”，「とされる」是引述评价的受身。"
      },
      {
        "marker": "⑩",
        "title": "～所以である（ゆえんである）",
        "desc": "「参考とされる所以である」——“这正是它被用作参考的缘由”。文语名词「所以（ゆえん）」结句，意为“……的缘由、原因”。"
      }
    ],
