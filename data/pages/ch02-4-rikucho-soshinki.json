  "grammar": {
    "cards": [
      {
        "marker": "①",
        "title": "～になると（时间・条件）",
        "desc": "「降って六朝時代になると、小説も多くあらわれる」——“降至六朝时代，小说也大量涌现”。「（时代）になると」表“一到……便……”，引出新阶段。"
      },
      {
        "marker": "②",
        "title": "意志・勧誘「～(よ)う」",
        "desc": "「『捜神記』に例をとろう」——“且以《搜神记》为例吧”。动词未然形＋「う／よう」（とる→とろう）表说话者的意志、提议。"
      },
      {
        "marker": "③",
        "title": "引用「～という」（漢文訓読調）",
        "desc": "「〔白文〕という。冤死の話である」——「という」承上文所引白文，意为“（其文）如此说／内容如下”。又「三年不雨という事態」中「という」作连体提示，复指前项内容。"
      },
      {
        "marker": "④",
        "title": "受身「～される」＋「～によって」",
        "desc": "「誤った裁判によって処刑され」——“因错判而被处死”。被动态「処刑される」＋「～によって」表施事或原因，全段叙事多用受身（殺され／訴えられる／救われる）。"
      },
      {
        "marker": "⑤",
        "title": "因果の「ために」",
        "desc": "「冤死し、ために三年不雨という事態をひきおこす」——“因（其）冤死，遂招致三年不雨之事”。句首「ために」承前指代原因，意为“因此、为此”，区别于“为了”。"
      },
      {
        "marker": "⑥",
        "title": "連用中止法（～し、～、）",
        "desc": "「許婚が他に嫁ぎ死ぬ」「冤死し、ために…」用连用形（嫁ぎ・冤死し）连接并列或承接小句，不加接续助词，是简洁的书面・训读体句法。"
      },
      {
        "marker": "⑦",
        "title": "～したところ（契机・顺承）",
        "desc": "「王に奏上したところ…許された」——“奏报于王，（结果）……得到准许”。「～したところ」表“做了……之后，（随即出现某结果）”的既定契机。"
      },
