  "grammar": {
    "cards": [
      {
        "marker": "①",
        "title": "～にくい",
        "desc": "「通りにくい」「いいにくい」——接动词连用形，“难以……、不容易……”。「とはいいにくい」＝“很难说……”。"
      },
      {
        "marker": "②",
        "title": "～ことのできる＋名词",
        "desc": "「うかがうことのできる貴重な資料価値」——“能够窥见……的宝贵史料价值”。「ことのできる」是「ことができる」的连体形，修饰后续名词。"
      },
      {
        "marker": "③",
        "title": "～といえるようにおもう",
        "desc": "「価値をもつといえるようにおもう」——“我觉得似乎可以说具有……价值”。是「～といえる」(可以说)＋「ようにおもう」(总觉得)的双重委婉判断，学术文常见的谦抑表达。"
      },
      {
        "marker": "④",
        "title": "～のであるから",
        "desc": "「素材とするのであるから」——“正因为是以……为素材”。「のである」加强说明语气，「から」表原因，书面因果句式。"
      },
      {
        "marker": "⑤",
        "title": "～できよう／見うるであろう（推量の「よう」）",
        "desc": "「知ることができよう」「見うるであろう」——“大概能够……吧”。「よう／であろう」是文语推量，使陈述显得审慎。"
      },
      {
        "marker": "⑥",
        "title": "～し（できようし）",
        "desc": "「垣間みることができようし、…も見うる」——并列叠加理由／事项，“既能……，也能……”。"
      },
      {
        "marker": "⑦",
        "title": "～所以である（ゆえんである）",
        "desc": "「ここに取上げる所以である」——“这就是（在此）将其取来论述的缘由”。「所以（ゆえん）」是文语名词“缘由、原因”。"
      },
      {
        "marker": "⑧",
        "title": "ところで",
        "desc": "转换话题的接续词，“且说、话说回来”。由前文“价值”的论述转入“公案”一词的来历。"
      },
      {
        "marker": "⑨",
        "title": "～かとおもわれる",
        "desc": "「宋代にはじまるかとおもわれる」——“觉得似乎始于宋代吧”。「か」表不确定，「おもわれる」是自发态，语气审慎。"
      },
      {
        "marker": "⑩",
        "title": "～にかぎらず",
        "desc": "「裁判にかぎらず」——“不限于审判”。「～に限らず」表示范围不止于此。"
      }
    ],
    "note": "※ 语法分析以现代日语+文语残留为对象，汉文（白文）引用部分保持原貌。"
  },
  "notes": [
    {
      "label": "本节定位",
      "text": "承接前两节对公案小说“不被当作小说”的评价，作者在此为公案小说翻案——指出其作为庶民生活、犯罪与司法的史料价值；随后转入“公案”一词的语源，追溯到宋代说话伎艺。"
    },
    {
      "label": "OCR订正",
      "text": "底本「でぁる」→「である」；「羅嘩」→「羅燁」（罗烨，《醉翁谈录》编者）；「小説開間」→「小説開闢」（篇名“小说开辟”）；公案篇目清单原OCR句首有衍字“言”，已删。"
    },
    {
      "label": "《醉翁谈录》八类",
      "text": "罗烨《醉翁谈录·小说开辟》将“小说”（说话之一家）分为灵怪、烟粉、传奇、公案、朴刀、杆棒、妖术、神仙等类，“公案”为其一。"
    },
    {
      "label": "篇目清单存疑",
      "text": "所列公案话本篇目多为孤证，文字传写与OCR均有不确定处——作者本人即于「憂」下加按语「〔疑是夏〕」（疑当作“夏”）；“瞳探児／火次籠／大朝国寺”等亦可能有讹，谨依底本照录，留待考订。"
    },
    {
      "label": "「一異面」",
      "text": "此词底本作「一異面」，意为“（犯罪这一）异常／阴暗的侧面”，但属生僻搭配，亦不排除OCR致误，姑依原文并注音 いちいめん。"
    },
    {
      "label": "都市繁昌记",
      "text": "《都城纪胜》《梦粱录》《古杭梦游录》均为南宋记述都城（临安）繁华的笔记，其“小说”条下出现“说公案”，是“公案”入小说门类的早期证据。"
    }
  ],
