  "grammar": {
    "cards": [
      {
        "marker": "①",
        "title": "～という＋名词",
        "desc": "「私情公案…という項目」——“叫做……的条目”。「という」引出名称，修饰后面的名词。"
      },
      {
        "marker": "②",
        "title": "～と題する",
        "desc": "「『張氏夜奔呂星可』と題する一則」——“题为《……》的一则”。「題する」＝命名、题作，多用于书名篇名。"
      },
      {
        "marker": "③",
        "title": "～られる（受身：おさめられる／下される）",
        "desc": "「一則がおさめられる」「判決が下される」——被动态，“被收录”“（判决）被下达”。学术叙述常用被动以隐去主语。"
      },
      {
        "marker": "④",
        "title": "～たとき",
        "desc": "「十六になったとき」——“当（到了）十六岁的时候”。「動詞た形＋とき」表时间点。"
      },
      {
        "marker": "⑤",
        "title": "～ので",
        "desc": "「縁談をすすめたので、駈落ちする」——“因为……所以……”。表客观、顺接的因果。"
      },
      {
        "marker": "⑥",
        "title": "それに対して",
        "desc": "「それに対して星可も訴え」——“对此、与之相对”。承接前句，引出相对的动作或一方。"
      },
      {
        "marker": "⑦",
        "title": "まず～、つづいて～",
        "desc": "「まず事件のあらましが述べられ、つづいて官府の判詞がのべられる」——“先……接着……”，叙述先后顺序的固定搭配。"
      },
      {
        "marker": "⑧",
        "title": "～をおびる",
        "desc": "「詼諧の性質をおび」——“带有……的性质”。「～を帯びる」表示具有某种倾向、色彩。"
      },
      {
        "marker": "⑨",
        "title": "あるいは～",
        "desc": "「詩の体をとり、あるいは駢語を用いる」——“或者……”，列举并列的可能方式。"
      },
      {
        "marker": "⑩",
        "title": "～も～もともに…",
        "desc": "「私情公案も花判公案もともに裁判にかかわる」——“……和……都同样与……有关”。「も…も」并列，「ともに」强调“两者皆然”。句末「知られよう」为推量“可见／想必可知”。"
      }
    ],
    "note": "※ 语法分析以现代日语+文语残留为对象，汉文（白文）引用部分保持原貌。"
  },
  "notes": [
    {
      "label": "本节定位",
      "text": "续举《醉翁谈录》中“私情公案”“花判公案”二目为证，进一步说明宋代“公案”一词的内核在于“裁判（判词）”，为下一节归结“公案与小说相结合始于宋代”作铺垫。"
    },
    {
      "label": "OCR订正",
      "text": "底本「星毒」→「星可」（人名吕星可）；「該諧」→「詼諧」；「餅語」→「駢語」；「閥文」→「闕文」；「花判とよ（れ、というｏ」→「花判とよばれ、という。」。"
    },
    {
      "label": "花判",
      "text": "指判词写得诙谐、并以诗体或骈俪之语出之的“美文判词”，是唐宋判牍的一种风尚（可参唐·张鷟《龙筋凤髓判》、白居易《甲乙判》）。“花”取其辞藻华美、游戏笔墨之意。"
    },
    {
      "label": "枢密",
      "text": "即枢密院长官（枢密使／副使），宋代掌军政机要的高位；“陈枢密”即一位姓陈的枢密大臣。"
    },
    {
      "label": "句末「とよばれ、という」",
      "text": "底本此处句法略松（「を…とよばれ」），意即“（这种判词）被称为花判，据云如此”，译文从其意。"
    }
  ],
